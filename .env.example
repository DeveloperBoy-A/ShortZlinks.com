# ==========================================
# 1. CORE SERVER SETTINGS
# ==========================================
PORT=3000
NODE_ENV=development
SITE_NAME="ShortZlinks"
BASE_URL="http://localhost:3000"

# ==========================================
# 2. DATABASE CONFIGURATION
# ==========================================
MONGO_URI="mongodb://localhost:27017/shortzlinks"
# Note: Agar aap MongoDB Atlas (Cloud) use kar rahe hain, toh yahan apna Atlas URI daalein.

# ==========================================
# 3. SECURITY & SESSIONS (Do not share these!)
# ==========================================
SESSION_SECRET="generate_a_random_long_string_here_for_sessions"
JWT_SECRET="generate_another_random_string_for_ad_step_tokens"

# ==========================================
# 4. ADMIN DEFAULTS (Auto-created on first boot)
# ==========================================
# Jab aap pehli baar is email se register karenge, system automatically aapko Super Admin bana dega.
ADMIN_EMAIL="admin@shortzlinks.com"
ADMIN_PASSWORD="SuperSecurePassword123!"

# ==========================================
# 5. EXTERNAL APIs (Anti-Fraud & Captcha)
# ==========================================
# Proxycheck.io API key to block VPNs and Datacenter IPs
PROXYCHECK_API_KEY="your_proxycheck_io_api_key"

# Cloudflare Turnstile / reCAPTCHA Secret Key
TURNSTILE_SECRET_KEY="your_cloudflare_turnstile_secret"

# ==========================================
# 6. EMAIL & SMTP SETTINGS
# ==========================================
# Primary Method (SMTP - e.g., Gmail App Password or Hostinger Webmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# Fallback Method (Email API - Brevo / Sendinblue)
# Agar SMTP limit cross hoti hai, toh system automatically is API key ka use karega
EMAIL_API_KEY="your_brevo_api_key_here"

# ==========================================
# 7. BUSINESS LOGIC SETTINGS
# ==========================================
# Referral commission percentage (e.g., 5 means users get 5% of their referral's earnings)
REFERRAL_PERCENT=5
