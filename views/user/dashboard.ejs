<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6">Welcome back, User!</h1>
        
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow mb-8">
            <form action="/user/links/create" method="POST" class="flex gap-4">
                <input type="url" name="originalUrl" placeholder="Paste your long URL here..." required class="flex-1 p-4 border rounded-lg dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-primary outline-none text-lg">
                <button type="submit" class="bg-primary text-white px-8 py-4 rounded-lg font-bold hover:bg-indigo-700 shadow-md">Shorten <i class="fas fa-magic ml-2"></i></button>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border-l-4 border-primary">
                <p class="text-gray-500 text-sm font-semibold uppercase">Wallet Balance</p>
                <h3 class="text-3xl font-black">$<%= user.walletBalance.toFixed(2) %></h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border-l-4 border-green-500">
                <p class="text-gray-500 text-sm font-semibold uppercase">Lifetime Earnings</p>
                <h3 class="text-3xl font-black">$<%= user.lifetimeEarnings.toFixed(2) %></h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border-l-4 border-secondary">
                <p class="text-gray-500 text-sm font-semibold uppercase">Total Links</p>
                <h3 class="text-3xl font-black"><%= totalLinks %></h3>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
            <div class="p-4 border-b dark:border-gray-700 font-bold bg-gray-100 dark:bg-gray-700">Recent Links</div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-gray-600 dark:text-gray-400 border-b dark:border-gray-700">
                            <th class="p-4">Short Link</th>
                            <th class="p-4">Original URL</th>
                            <th class="p-4">Clicks</th>
                            <th class="p-4">Earnings</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% links.forEach(link => { %>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                <td class="p-4 text-primary font-medium">
                                    <a href="/<%= link.alias %>" target="_blank"><%= settings.defaultDomain %>/<%= link.alias %></a>
                                </td>
                                <td class="p-4 truncate max-w-xs" title="<%= link.originalUrl %>"><%= link.originalUrl %></td>
                                <td class="p-4"><%= link.totalClicks %></td>
                                <td class="p-4 text-green-500">$<%= link.validEarnings.toFixed(4) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
            <div class="p-4 border-b dark:border-gray-700 font-bold bg-gray-100 dark:bg-gray-700">
                <i class="fas fa-globe-americas text-blue-500 mr-2"></i> Top Demographics (Valid Clicks)
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-gray-600 dark:text-gray-400 border-b dark:border-gray-700">
                            <th class="p-4">Country</th>
                            <th class="p-4">Total Valid Clicks</th>
                            <th class="p-4">Total Earnings</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof countryStats !== 'undefined' && countryStats.length > 0) { %>
                            <% countryStats.forEach(stat => { %>
                                <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                    <td class="p-4 font-bold flex items-center">
                                        <img src="https://flagcdn.com/24x18/<%= stat._id === 'Unknown' ? 'xx' : stat._id.toLowerCase() %>.png" class="mr-3 shadow-sm border" alt="flag" onerror="this.style.display='none'"> 
                                        <%= stat._id === 'Unknown' ? 'Other/Proxy' : stat._id %>
                                    </td>
                                    <td class="p-4"><%= stat.clicks %></td>
                                    <td class="p-4 text-green-500 font-bold">$<%= stat.earnings.toFixed(4) %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="p-6 text-center text-gray-500">No geo-data available yet. Drive some traffic!</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</div>
<%- include('../partials/footer') %>
