<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6">Developer Tools</h1>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md mb-8 border-l-4 border-primary">
            <h2 class="text-xl font-bold mb-2"><i class="fas fa-layer-group text-primary mr-2"></i> Mass Shrinker</h2>
            <p class="text-gray-500 mb-4 text-sm">Enter up to 20 URLs (one per line) to shrink them all at once.</p>
            <form action="/user/links/mass" method="POST">
                <textarea name="urls" rows="5" required placeholder="https://example.com&#10;https://google.com" class="w-full p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-primary outline-none mb-4"></textarea>
                <button type="submit" class="bg-primary text-white px-6 py-2 rounded font-bold hover:bg-indigo-700 transition">Shrink All</button>
            </form>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-secondary">
            <h2 class="text-xl font-bold mb-2"><i class="fas fa-code text-secondary mr-2"></i> Full Page Script</h2>
            <p class="text-gray-500 mb-4 text-sm">If you have a website, copy and paste this code inside the <code>&lt;head&gt;</code> or <code>&lt;body&gt;</code> tag to automatically monetize all your outbound links.</p>
            
            <div class="bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm overflow-x-auto">
<pre>
&lt;script type="text/javascript"&gt;
    var shortz_domain = "<%= settings.defaultDomain %>";
    var shortz_api_token = "USER_API_TOKEN_HERE";
    var shortz_exclude_domains = ["yoursite.com", "mysite.com"];
&lt;/script&gt;
&lt;script src="<%= settings.defaultDomain %>/js/full-page-script.js"&gt;&lt;/script&gt;
</pre>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
