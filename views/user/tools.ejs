<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6">Developer Tools</h1>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md mb-8 border-l-4 border-primary">
            <h2 class="text-xl font-bold mb-2"><i class="fas fa-layer-group text-primary mr-2"></i> Mass Shrinker</h2>
            <p class="text-gray-500 mb-4 text-sm">Enter up to 20 URLs (one per line) to shrink them all at once.</p>
            
            <textarea id="massUrls" rows="5" required placeholder="https://example.com&#10;https://google.com" class="w-full p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-primary outline-none mb-4 font-mono text-sm"></textarea>
            
            <div class="flex items-center gap-4">
                <button id="shrinkBtn" onclick="processMassShrink()" class="bg-primary text-white px-6 py-2 rounded font-bold hover:bg-indigo-700 transition shadow-md">Shrink All</button>
                <span id="massStatus" class="font-bold text-green-500 hidden animate-pulse">Processing...</span>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-secondary">
            <h2 class="text-xl font-bold mb-2"><i class="fas fa-code text-secondary mr-2"></i> Full Page Script</h2>
            <p class="text-gray-500 mb-4 text-sm">If you have a website, copy and paste this code inside the <code>&lt;head&gt;</code> or <code>&lt;body&gt;</code> tag to automatically monetize all your outbound links.</p>
            
            <div class="bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm overflow-x-auto whitespace-pre">
&lt;script type="text/javascript"&gt;
    var shortz_domain = "<%= settings.defaultDomain %>";
    var shortz_api_token = "<%= user.apiToken %>"; var shortz_exclude_domains = ["yoursite.com", "mysite.com"];
&lt;/script&gt;
&lt;script src="<%= settings.defaultDomain %>/js/full-page-script.js"&gt;&lt;/script&gt;
            </div>
        </div>
    </main>
</div>

<script>
    async function processMassShrink() {
        const textarea = document.getElementById('massUrls');
        const btn = document.getElementById('shrinkBtn');
        const statusText = document.getElementById('massStatus');
        
        // Remove empty lines and spaces
        let urls = textarea.value.split('\n').map(url => url.trim()).filter(url => url.length > 0);
        
        if (urls.length === 0) return alert("Please enter at least one URL.");
        if (urls.length > 20) return alert("Maximum 20 URLs allowed at a time.");

        // UI Updates during processing
        btn.disabled = true;
        btn.innerText = "Processing...";
        btn.classList.add("opacity-50", "cursor-not-allowed");
        statusText.classList.remove('hidden');
        statusText.innerText = `0 / ${urls.length} Completed...`;

        let resultText = "";
        const apiToken = "<%= user.apiToken %>";
        const apiUrl = "<%= settings.defaultDomain %>/api";

        // Call the API endpoint for each URL
        for (let i = 0; i < urls.length; i++) {
            try {
                let response = await fetch(`${apiUrl}?api=${apiToken}&url=${encodeURIComponent(urls[i])}&format=text`);
                let shortUrl = await response.text();
                
                if (shortUrl) {
                    resultText += shortUrl + "\n";
                } else {
                    resultText += "Error processing: " + urls[i] + "\n";
                }
            } catch (err) {
                resultText += "Network Error for: " + urls[i] + "\n";
            }
            statusText.innerText = `${i + 1} / ${urls.length} Completed...`;
        }

        // Output results and reset UI
        textarea.value = resultText.trim();
        btn.disabled = false;
        btn.innerText = "Shrink All";
        btn.classList.remove("opacity-50", "cursor-not-allowed");
        statusText.innerText = "All Links Successfully Shortened!";
        
        // Hide success message after 4 seconds
        setTimeout(() => {
            statusText.classList.add('hidden');
        }, 4000);
    }
</script>

<%- include('../partials/footer') %>
