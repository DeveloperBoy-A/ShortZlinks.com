<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    
    <main class="flex-1 p-4 md:p-8 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <div class="max-w-5xl mx-auto">
            
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-md p-6 md:p-8 mb-8 flex flex-col md:flex-row items-center gap-6 border-b-4 border-primary relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-primary opacity-5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
                
                <div class="relative z-10 shrink-0">
                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-white dark:border-gray-700 shadow-xl overflow-hidden bg-blue-100">
                        <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=<%= user.email %>&backgroundColor=c0aede" alt="User Avatar" class="w-full h-full object-cover">
                    </div>
                    <div class="absolute bottom-1 right-2 w-5 h-5 bg-green-500 border-2 border-white dark:border-gray-800 rounded-full" title="Online"></div>
                </div>

                <div class="text-center md:text-left z-10">
                    <h1 class="text-3xl font-black text-gray-900 dark:text-white">
                        <%= user.firstName ? user.firstName + ' ' + user.lastName : 'Welcome, Publisher!' %>
                    </h1>
                    <p class="text-gray-500 dark:text-gray-400 font-medium text-lg mt-1"><i class="fas fa-envelope text-primary mr-2"></i> <%= user.email %></p>
                    <div class="mt-4 flex flex-wrap justify-center md:justify-start gap-2">
                        <span class="px-3 py-1 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 rounded-full text-xs font-bold uppercase tracking-wide"><i class="fas fa-check-circle mr-1"></i> Active</span>
                        <span class="px-3 py-1 bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 rounded-full text-xs font-bold uppercase tracking-wide"><i class="fas fa-id-badge mr-1"></i> <%= user.role %></span>
                    </div>
                </div>
            </div>

            <form action="/user/settings/update" method="POST" class="space-y-8">
                
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-md border-t-4 border-blue-500 overflow-hidden">
                    <div class="p-6 border-b dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50">
                        <h2 class="text-xl font-bold text-gray-800 dark:text-gray-100 flex items-center gap-2">
                            <i class="fas fa-user-edit text-blue-500"></i> Billing Identity
                        </h2>
                        <p class="text-sm text-gray-500 mt-1">This information must be accurate to process your payouts successfully.</p>
                    </div>
                    
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">First Name</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-user text-gray-400"></i></div>
                                <input type="text" name="firstName" value="<%= user.firstName %>" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Last Name</label>
                            <input type="text" name="lastName" value="<%= user.lastName %>" required class="w-full p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Address Line 1</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-home text-gray-400"></i></div>
                                <input type="text" name="address" value="<%= user.address %>" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">City</label>
                            <input type="text" name="city" value="<%= user.city %>" required class="w-full p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">State / Province</label>
                            <input type="text" name="state" value="<%= user.state %>" required class="w-full p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">ZIP / Postal Code</label>
                            <input type="text" name="zipCode" value="<%= user.zipCode %>" required class="w-full p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Country</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-globe-americas text-gray-400"></i></div>
                                <input type="text" name="country" value="<%= user.country %>" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Phone Number (with Country Code)</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-phone-alt text-gray-400"></i></div>
                                <input type="tel" name="phoneNumber" value="<%= user.phoneNumber %>" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 outline-none transition">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-md border-t-4 border-green-500 overflow-hidden">
                    <div class="p-6 border-b dark:border-gray-700 bg-green-50/30 dark:bg-green-900/10">
                        <h2 class="text-xl font-bold text-gray-800 dark:text-gray-100 flex items-center gap-2">
                            <i class="fas fa-money-check-alt text-green-500"></i> Withdrawal Settings
                        </h2>
                    </div>
                    
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Select Payment Method</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-university text-gray-400"></i></div>
                                <select id="paymentMethodSelect" name="preferredPaymentMethodId" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-green-500 outline-none transition appearance-none">
                                    <option value="">-- Choose Method --</option>
                                    <% paymentMethods.forEach(method => { %>
                                        <option
                                            value="<%= method._id %>"
                                            data-fields="<%= (method.fields || ['Account Details']).join('|') %>"
                                            <%= user.preferredPaymentMethodId && user.preferredPaymentMethodId.toString() === method._id.toString() ? 'selected' : '' %>
                                        >
                                            <%= method.name %> (Min: $<%= method.minPayout %>)
                                        </option>
                                    <% }) %>
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none"><i class="fas fa-chevron-down text-gray-400"></i></div>
                            </div>
                            <% if (paymentMethods.length === 0) { %>
                                <p class="text-xs text-red-500 mt-2"><i class="fas fa-exclamation-circle mr-1"></i> Abhi koi payment method available nahi hai. Admin se contact karein.</p>
                            <% } %>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Withdrawal Account Details</label>

                            <!-- Method select hone se pehle / fields na hone par yeh generic box dikhega -->
                            <div id="genericAccountField">
                                <input type="text" id="genericAccountInput" placeholder="Pehle upar se ek Payment Method chunein" disabled class="w-full p-3 border rounded-lg bg-gray-100 dark:bg-gray-900 dark:border-gray-700 outline-none">
                            </div>

                            <!-- Method select hone ke baad yahan uske specific fields (Account Number, IFSC, UPI ID, etc.) dikhenge -->
                            <div id="dynamicAccountFields" class="space-y-3 hidden"></div>

                            <!-- Yeh hidden input hi asal me DB me save hota hai (sab fields ko combine karke) -->
                            <input type="hidden" name="withdrawalAccountDetails" id="withdrawalAccountDetails" value="<%= user.withdrawalAccountDetails %>">

                            <p class="text-xs text-gray-500 mt-2 font-medium"><i class="fas fa-exclamation-triangle text-yellow-500 mr-1"></i> Ensure this is 100% accurate to prevent failed payouts.</p>
                        </div>
                    </div>
                    
                    <div class="p-6 bg-gray-50 dark:bg-gray-800/80 border-t dark:border-gray-700 flex justify-end">
                        <button type="submit" class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-8 py-3 rounded-lg font-bold hover:shadow-lg hover:-translate-y-1 transition transform w-full md:w-auto">
                            <i class="fas fa-save mr-2"></i> Save Profile & Payout Settings
                        </button>
                    </div>
                </div>
            </form>

            <div class="mt-8 bg-white dark:bg-gray-800 rounded-2xl shadow-md border-t-4 border-red-500 overflow-hidden">
                <div class="p-6 border-b dark:border-gray-700 bg-red-50/50 dark:bg-red-900/10">
                    <h2 class="text-xl font-bold text-red-600 dark:text-red-400 flex items-center gap-2">
                        <i class="fas fa-shield-alt"></i> Security & Login Details
                    </h2>
                </div>
                
                <form action="/user/settings/security" method="POST" class="p-6 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Update Email Address</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-envelope text-gray-400"></i></div>
                                <input type="email" name="email" value="<%= user.email %>" required class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-red-500 outline-none transition">
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">New Password (Optional)</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-key text-gray-400"></i></div>
                                <input type="password" name="newPassword" placeholder="Leave blank to keep current" class="w-full pl-10 p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-red-500 outline-none transition">
                            </div>
                        </div>
                    </div>

                    <div class="bg-red-50 dark:bg-red-900/20 p-5 rounded-xl border border-red-100 dark:border-red-900/50 mt-4">
                        <label class="block text-sm font-bold text-red-700 dark:text-red-400 mb-2 flex items-center gap-2">
                            <i class="fas fa-lock"></i> Current Password (Required to save changes)
                        </label>
                        <input type="password" name="currentPassword" required placeholder="Enter your current password to verify identity" class="w-full p-3 border rounded-lg bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-red-500 outline-none transition">
                    </div>

                    <div class="flex justify-end pt-4">
                        <button type="submit" class="bg-red-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-red-700 hover:shadow-lg transition w-full md:w-auto">
                            Update Security Info
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var select = document.getElementById('paymentMethodSelect');
    var dynamicContainer = document.getElementById('dynamicAccountFields');
    var genericField = document.getElementById('genericAccountField');
    var hiddenInput = document.getElementById('withdrawalAccountDetails');
    if (!select || !dynamicContainer || !hiddenInput) return;

    // Pehle se saved value ko "Label: value" pairs me todne ki koshish karo,
    // taaki edit karte waqt purani values wapas fields me dikhein.
    function parseExistingValue(rawValue) {
        var map = {};
        if (!rawValue) return map;
        rawValue.split('|').forEach(function (part) {
            var idx = part.indexOf(':');
            if (idx === -1) return;
            var label = part.slice(0, idx).trim();
            var value = part.slice(idx + 1).trim();
            if (label) map[label] = value;
        });
        return map;
    }

    function renderFields() {
        var opt = select.options[select.selectedIndex];
        var fieldsAttr = opt ? opt.getAttribute('data-fields') : '';

        if (!fieldsAttr) {
            // Koi method select nahi hua
            dynamicContainer.classList.add('hidden');
            dynamicContainer.innerHTML = '';
            genericField.classList.remove('hidden');
            return;
        }

        genericField.classList.add('hidden');
        dynamicContainer.classList.remove('hidden');
        dynamicContainer.innerHTML = '';

        var fields = fieldsAttr.split('|').filter(Boolean);
        var existing = parseExistingValue(hiddenInput.value);

        fields.forEach(function (label, i) {
            var wrapper = document.createElement('div');
            var input = document.createElement('input');
            input.type = 'text';
            input.placeholder = label;
            input.dataset.label = label;
            input.required = true;
            input.value = existing[label] || '';
            input.className = 'w-full p-3 border rounded-lg bg-gray-50 dark:bg-gray-900 dark:border-gray-700 focus:ring-2 focus:ring-green-500 outline-none transition mb-2';

            var labelEl = document.createElement('label');
            labelEl.className = 'block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1';
            labelEl.textContent = label;

            wrapper.appendChild(labelEl);
            wrapper.appendChild(input);
            dynamicContainer.appendChild(wrapper);
        });
    }

    function combineFieldsIntoHiddenInput() {
        var inputs = dynamicContainer.querySelectorAll('input[data-label]');
        if (inputs.length === 0) return; // generic field ka value already hidden input me set hai
        var parts = [];
        inputs.forEach(function (input) {
            parts.push(input.dataset.label + ': ' + input.value.trim());
        });
        hiddenInput.value = parts.join(' | ');
    }

    select.addEventListener('change', renderFields);

    // Form submit hone se theek pehle dynamic fields ko ek single string me combine karo
    var form = select.closest('form');
    if (form) {
        form.addEventListener('submit', function (e) {
            combineFieldsIntoHiddenInput();
            var inputs = dynamicContainer.querySelectorAll('input[data-label]');
            for (var i = 0; i < inputs.length; i++) {
                if (!inputs[i].value.trim()) {
                    e.preventDefault();
                    alert(inputs[i].dataset.label + ' bharna zaroori hai.');
                    inputs[i].focus();
                    return;
                }
            }
        });
    }

    // Page load par agar pehle se method selected hai to uske fields turant dikhao
    renderFields();
});
</script>
<%- include('../partials/footer') %>