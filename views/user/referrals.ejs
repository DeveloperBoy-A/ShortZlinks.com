<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-4 md:p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <div class="max-w-4xl mx-auto space-y-6">

            <h1 class="text-2xl md:text-3xl font-black text-gray-800 dark:text-white">
                <i class="fas fa-user-friends text-yellow-500 mr-2"></i> Referral Program
            </h1>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-l-4 border-yellow-400">
                <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Apna referral link dosto ke saath share karein. Jab bhi koi is link se sign up karega,
                    aapko unki earnings ka <strong><%= typeof referralPercent !== 'undefined' ? referralPercent : 5 %>%</strong> bonus milega.
                </p>

                <div class="flex flex-col md:flex-row gap-3">
                    <input
                        id="referralLinkInput"
                        type="text"
                        readonly
                        value="<%= referralLink %>"
                        class="flex-1 p-3 border rounded-lg dark:bg-gray-700 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-gray-800 dark:text-gray-100 font-mono text-sm outline-none"
                    >
                    <button id="copyReferralBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-bold transition shadow-md whitespace-nowrap">
                        <i class="fas fa-copy mr-1"></i> Copy Link
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-white dark:bg-gray-800 p-5 rounded-xl shadow-sm border-l-4 border-blue-500 flex justify-between items-center relative overflow-hidden">
                    <div class="z-10">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Total Referrals</p>
                        <h3 class="text-3xl font-black text-gray-800 dark:text-white"><%= referralCount %></h3>
                    </div>
                    <i class="fas fa-users text-4xl text-blue-100 dark:text-gray-700 absolute right-4"></i>
                </div>
                <div class="bg-white dark:bg-gray-800 p-5 rounded-xl shadow-sm border-l-4 border-green-500 flex justify-between items-center relative overflow-hidden">
                    <div class="z-10">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Referral Earnings</p>
                        <h3 class="text-3xl font-black text-gray-800 dark:text-white">
                            $<%= user.referralEarnings ? user.referralEarnings.toFixed(4) : '0.0000' %>
                        </h3>
                    </div>
                    <i class="fas fa-hand-holding-usd text-4xl text-green-100 dark:text-gray-700 absolute right-4"></i>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <h4 class="font-bold text-gray-800 dark:text-gray-100 mb-2">
                    <i class="fas fa-info-circle text-blue-500 mr-1"></i> Yeh kaise kaam karta hai
                </h4>
                <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1 list-disc list-inside">
                    <li>Apna unique link upar se copy karein.</li>
                    <li>Ise apne dosto, social media ya YouTube channel pe share karein.</li>
                    <li>Jab koi us link se register karega, wo permanently aapke account se link ho jayega.</li>
                    <li>Unki har valid earning par aapko bonus commission milega, apne aap wallet me add ho jayega.</li>
                </ul>
            </div>

        </div>
    </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var copyBtn = document.getElementById('copyReferralBtn');
    var input = document.getElementById('referralLinkInput');
    if (copyBtn && input) {
        copyBtn.addEventListener('click', function () {
            input.select();
            input.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(input.value).then(function () {
                copyBtn.innerHTML = '<i class="fas fa-check mr-1"></i> Copied!';
                setTimeout(function () {
                    copyBtn.innerHTML = '<i class="fas fa-copy mr-1"></i> Copy Link';
                }, 2000);
            }).catch(function () {
                document.execCommand('copy');
            });
        });
    }
});
</script>

<%- include('../partials/footer') %>