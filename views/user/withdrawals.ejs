<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6">Withdraw Earnings</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md flex items-center justify-between border-t-4 border-green-500">
                <div>
                    <p class="text-gray-500 text-sm font-bold uppercase mb-1">Available Balance</p>
                    <h2 class="text-4xl font-black text-green-600 dark:text-green-400">$<%= user.walletBalance.toFixed(2) %></h2>
                </div>
                <i class="fas fa-wallet text-5xl text-gray-200 dark:text-gray-700"></i>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-primary">
                <h3 class="font-bold text-lg mb-4">Request Payout</h3>
                <form action="/user/withdrawals/request" method="POST">
                    <div class="mb-4">
                        <label class="block text-sm font-medium mb-1">Mandatory Traffic Source</label>
                        <input type="text" name="trafficSource" placeholder="e.g., YouTube Channel, Telegram Group link..." required class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-primary outline-none">
                        <p class="text-xs text-gray-500 mt-1">We verify traffic to protect advertisers. Fake traffic will result in account ban.</p>
                    </div>
                    <button type="submit" class="w-full bg-primary text-white py-2 rounded font-bold hover:bg-indigo-700 transition">Submit Request</button>
                </form>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
            <div class="p-4 bg-gray-100 dark:bg-gray-700 font-bold border-b dark:border-gray-600">Payment History</div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-gray-600 dark:text-gray-400 border-b dark:border-gray-700">
                            <th class="p-4">ID</th>
                            <th class="p-4">Amount</th>
                            <th class="p-4">Method</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% history.forEach(req => { %>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                <td class="p-4 font-mono text-sm">#<%= req._id.toString().substring(18,24) %></td>
                                <td class="p-4 font-bold text-green-500">$<%= req.amount.toFixed(2) %></td>
                                <td class="p-4"><%= req.method %></td>
                                <td class="p-4">
                                    <% if (req.status === 'Pending') { %><span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded-full text-xs font-bold">Pending</span><% } %>
                                    <% if (req.status === 'Approved') { %><span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-bold">Processing</span><% } %>
                                    <% if (req.status === 'Completed') { %><span class="px-2 py-1 bg-green-100 text-green-800 rounded-full text-xs font-bold">Completed</span><% } %>
                                    <% if (req.status === 'Returned') { %><span class="px-2 py-1 bg-red-100 text-red-800 rounded-full text-xs font-bold">Returned</span><% } %>
                                </td>
                                <td class="p-4 text-sm text-gray-500"><%= req.createdAt.toLocaleDateString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
