<%- include('../partials/header') %>
<main class="flex-grow max-w-7xl mx-auto w-full p-6 flex flex-col md:flex-row gap-6 items-start mt-10">
    
    <div class="hidden md:flex flex-col w-1/3 bg-gray-100 dark:bg-gray-800 min-h-[600px] rounded-lg items-center justify-center p-4">
        <p class="text-xs text-gray-400 mb-2">Advertisement</p>
        </div>

    <div class="w-full md:w-2/3 bg-white dark:bg-gray-800 p-10 rounded-xl shadow-2xl text-center border-l-4 border-secondary">
        
        <div class="w-full flex justify-center mb-8 min-h-[90px] bg-gray-50 dark:bg-gray-700">
             </div>

        <h1 class="text-3xl font-black mb-4 text-gray-800 dark:text-gray-100">Verification in Progress</h1>
        <p class="text-lg text-gray-500 mb-8">Step <%= step %> out of <%= totalSteps %> is currently processing.</p>
        
        <div class="flex justify-center items-center gap-4 mb-8">
            <i class="fas fa-shield-alt text-4xl text-green-500"></i>
            <div class="text-6xl font-black text-secondary" id="timerDisplay">10</div>
        </div>
        
        <p id="instructionText" class="text-sm font-bold text-gray-400 mb-8 animate-pulse">Analyzing traffic quality...</p>

        <a id="continueBtn" href="#" class="hidden w-full md:w-2/3 mx-auto bg-primary text-white py-4 px-6 rounded-full font-black text-xl hover:bg-indigo-700 transition shadow-xl transform hover:scale-105">
            Continue to Next Step
        </a>
    </div>

</main>
<%- include('timer-script') %>
<%- include('../partials/footer') %>

