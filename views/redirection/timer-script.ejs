<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        let timeLeft = 10; // 10 seconds timer
        const timerDisplay = document.getElementById('timerDisplay');
        const instructionText = document.getElementById('instructionText');
        const continueBtn = document.getElementById('continueBtn');
        const token = "<%= token %>";

        const countdown = setInterval(() => {
            timeLeft--;
            if(timerDisplay) timerDisplay.innerText = timeLeft;
            
            if (timeLeft <= 0) {
                clearInterval(countdown);
                if(timerDisplay) timerDisplay.innerText = "0";
                if(instructionText) instructionText.innerText = "Processing request securely...";
                
                fetch('/l/step/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ t: token })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.nextUrl) {
                        if(timerDisplay) timerDisplay.parentElement.style.display = 'none';
                        if(instructionText) instructionText.innerText = "Verification Complete!";
                        continueBtn.href = data.nextUrl;
                        continueBtn.classList.remove('hidden');
                        
                        gsap.to(continueBtn, { scale: 1.03, repeat: -1, yoyo: true, duration: 0.6 });
                    } else {
                        if(instructionText) instructionText.innerText = "Error processing request.";
                    }
                })
                .catch(err => {
                    if(instructionText) instructionText.innerText = "Network Error. Please reload.";
                });
            }
        }, 1000);
    });
</script>


