<%- include('partials/header') %>
<main class="flex-grow flex items-center justify-center p-6 bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg max-w-2xl w-full border-t-4 border-red-500">
        <h2 class="text-3xl font-black mb-4">Report Abuse / DMCA</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">If you found a link generated by our users that violates copyrights, contains malware, or breaks our Terms of Service, please report it below. We will remove it within 24 hours.</p>
        
        <form action="/report-abuse" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium mb-1">Reported Short Link</label>
                <input type="url" name="reportedUrl" required placeholder="https://shortz.com/alias" class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Your Email</label>
                    <input type="email" name="email" required class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Reason</label>
                    <select name="reason" required class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none bg-white dark:bg-gray-700">
                        <option value="Copyright (DMCA)">Copyright (DMCA)</option>
                        <option value="Malware/Virus">Malware / Virus</option>
                        <option value="Phishing">Phishing / Scam</option>
                        <option value="Other">Other Abuse</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Additional Details</label>
                <textarea name="message" rows="4" required class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none"></textarea>
            </div>
            <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded font-bold hover:bg-red-700 transition w-full">Submit Report</button>
        </form>
    </div>
</main>
<%- include('partials/footer') %>

