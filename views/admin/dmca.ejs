<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-red-600">DMCA & Abuse Reports</h1>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 dark:bg-gray-700 border-b dark:border-gray-600">
                            <th class="p-4">Reported Link</th>
                            <th class="p-4">Reason & Reporter</th>
                            <th class="p-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof reports === 'undefined' || reports.length === 0) { %>
                            <tr><td colspan="3" class="p-4 text-center text-gray-500">System is clean. No pending reports!</td></tr>
                        <% } else { %>
                            <% reports.forEach(r => { %>
                                <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    <td class="p-4 max-w-xs truncate" title="<%= r.reportedUrl %>"><%= r.reportedUrl %></td>
                                    <td class="p-4">
                                        <span class="font-bold"><%= r.reason %></span>
                                        <div class="text-xs text-gray-500"><%= r.email %></div>
                                    </td>
                                    <td class="p-4">
                                        <span class="px-2 py-1 rounded text-xs <%= r.status === 'Resolved' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>"><%= r.status %></span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>