<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-primary">User Management</h1>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 border-b dark:border-gray-600">
                            <th class="p-4">Email</th>
                            <th class="p-4">Role</th>
                            <th class="p-4">Wallet Balance</th>
                            <th class="p-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="p-4 font-bold"><%= u.email %></td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded text-xs <%= u.role === 'admin' ? 'bg-red-100 text-red-800' : 'bg-blue-100 text-blue-800' %>"><%= u.role %></span>
                                </td>
                                <td class="p-4 text-green-500 font-bold">$<%= u.walletBalance.toFixed(2) %></td>
                                <td class="p-4">
                                    <a href="/admin/users/<%= u._id %>" class="bg-gray-200 dark:bg-gray-600 px-3 py-1 rounded text-sm hover:bg-gray-300">Inspect <i class="fas fa-search ml-1"></i></a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>

