<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-red-600">Super Admin Configuration</h1>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-red-500">
                <h3 class="font-bold text-lg mb-4">Core Revenue Settings</h3>
                <form action="/admin/settings" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Base CPM ($) - Per 1000 Valid Clicks</label>
                        <input type="number" step="0.01" name="baseCpm" value="<%= settings.baseCpm %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-red-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Admin Commission Margin (%)</label>
                        <input type="number" name="adminCommissionPercent" value="<%= settings.adminCommissionPercent %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-red-500 outline-none">
                        <p class="text-xs text-gray-500 mt-1">If set to 20%, you keep 20%, and the user gets 80% of the calculated ad revenue.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Verification Ad Pages (1 to 4 steps)</label>
                        <input type="number" name="adSteps" min="1" max="4" value="<%= settings.adSteps %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-red-500 outline-none">
                        <p class="text-xs text-gray-500 mt-1">How many intermediate timer pages the visitor must skip.</p>
                    </div>
                    <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded font-bold hover:bg-red-700">Save Core Settings</button>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-green-500">
                <h3 class="font-bold text-lg mb-4">Create New Payment Method</h3>
                <form action="/admin/settings/payment-methods" method="POST" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1">Method Name (e.g. PhonePe)</label>
                            <input type="text" name="name" required class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-green-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">Minimum Payout ($)</label>
                            <input type="number" name="minPayout" required class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-green-500 outline-none">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Icon Class (FontAwesome)</label>
                        <input type="text" name="iconClass" value="fas fa-money-bill" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-green-500 outline-none">
                    </div>
                    <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded font-bold hover:bg-green-700">Add Method</button>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-blue-500 xl:col-span-2">
                <h3 class="font-bold text-lg mb-4">Multi-Domain Manager</h3>
                <p class="text-sm text-gray-500 mb-4">Add multiple short domains to evade ISP bans (e.g., shortz1.com, shortz2.com).</p>
                <form action="/admin/settings/domain" method="POST" class="flex gap-4">
                    <input type="text" name="newDomain" placeholder="https://newdomain.com" required class="flex-1 p-2 border rounded dark:bg-gray-700 dark:border-gray-600 focus:ring-2 focus:ring-blue-500 outline-none">
                    <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded font-bold hover:bg-blue-700">Add Domain</button>
                </form>
                <div class="mt-4">
                    <% settings.activeDomains.forEach(domain => { %>
                        <span class="inline-block bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm mr-2 mb-2"><%= domain %></span>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
