<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-red-600">Super Admin Configuration</h1>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-red-500 xl:col-span-2">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2"><i class="fas fa-chart-line text-red-500"></i> Revenue & CPM Engine</h3>
                <form action="/admin/settings/update-cpm" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium mb-1">Global Default CPM ($)</label>
                        <input type="number" step="0.01" name="baseCpm" value="<%= settings.defaultCpm %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Admin Profit Margin (%)</label>
                        <input type="number" name="adminCommissionPercent" value="<%= settings.adminCommissionPercent %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Verification Ad Steps</label>
                        <input type="number" name="adSteps" min="1" max="4" value="<%= settings.adSteps %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    
                    <div class="md:col-span-3">
                        <label class="block text-sm font-medium mb-1">Country-Wise CPM Rates (JSON Format)</label>
                        <textarea name="countryRates" rows="4" class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 font-mono text-sm outline-none"><%= JSON.stringify(Object.fromEntries(settings.countryRates)) %></textarea>
                        <p class="text-xs text-gray-500 mt-1">Format example: {"US": 10.00, "IN": 5.00, "GB": 8.00}</p>
                    </div>

                    <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded font-bold hover:bg-red-700">Save CPM Engine</button>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-green-500 xl:col-span-2">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2"><i class="fas fa-wallet text-green-500"></i> Payment Methods</h3>

                <form action="/admin/settings/payment-methods" method="POST" class="space-y-4 mb-6 bg-gray-50 dark:bg-gray-900/40 p-4 rounded-lg border dark:border-gray-700">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1">Method Name</label>
                            <input type="text" name="name" required placeholder="e.g. Bank Transfer" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">Min Payout ($)</label>
                            <input type="number" step="0.01" name="minPayout" required placeholder="5" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">Icon Class (optional)</label>
                            <input type="text" name="iconClass" placeholder="fas fa-university" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">
                            Fields user ko bharne honge (comma se separate karein)
                        </label>
                        <input type="text" name="fields" required placeholder="Account Holder Name, Account Number, IFSC Code, Bank Name" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        <p class="text-xs text-gray-500 mt-1">Example — UPI: <code>UPI ID</code> | PayPal: <code>PayPal Email</code> | Bank: <code>Account Holder Name, Account Number, IFSC Code, Bank Name</code></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Instructions for user (optional)</label>
                        <input type="text" name="instructions" placeholder="e.g. Enter your active UPI ID linked to your bank" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    </div>
                    <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded font-bold hover:bg-green-700 w-full">Add Method</button>
                </form>

                <h4 class="font-bold text-sm mb-2 text-gray-500 uppercase tracking-wide">Currently Added Methods</h4>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="text-gray-600 dark:text-gray-400 border-b dark:border-gray-700 bg-gray-100 dark:bg-gray-700">
                                <th class="p-3">Name</th>
                                <th class="p-3">Min Payout</th>
                                <th class="p-3">Required Fields</th>
                                <th class="p-3">Status</th>
                                <th class="p-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (paymentMethods && paymentMethods.length > 0) { %>
                                <% paymentMethods.forEach(method => { %>
                                    <tr class="border-b dark:border-gray-700">
                                        <td class="p-3 font-bold flex items-center gap-2">
                                            <i class="<%= method.iconClass || 'fas fa-wallet' %> text-gray-400"></i> <%= method.name %>
                                        </td>
                                        <td class="p-3">$<%= method.minPayout %></td>
                                        <td class="p-3 text-xs text-gray-500"><%= (method.fields || []).join(', ') %></td>
                                        <td class="p-3">
                                            <% if (method.isActive) { %>
                                                <span class="px-2 py-1 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 rounded-full text-xs font-bold">● Active</span>
                                            <% } else { %>
                                                <span class="px-2 py-1 bg-gray-200 text-gray-600 dark:bg-gray-700 dark:text-gray-400 rounded-full text-xs font-bold">○ Inactive</span>
                                            <% } %>
                                        </td>
                                        <td class="p-3">
                                            <div class="flex gap-2">
                                                <form action="/admin/settings/payment-methods/<%= method._id %>/toggle" method="POST">
                                                    <button type="submit" class="px-3 py-1 rounded text-xs font-bold <%= method.isActive ? 'bg-yellow-100 text-yellow-700 hover:bg-yellow-200' : 'bg-green-100 text-green-700 hover:bg-green-200' %>">
                                                        <%= method.isActive ? 'Deactivate' : 'Activate' %>
                                                    </button>
                                                </form>
                                                <form action="/admin/settings/payment-methods/<%= method._id %>/delete" method="POST" onsubmit="return confirm('Delete this payment method?');">
                                                    <button type="submit" class="px-3 py-1 rounded text-xs font-bold bg-red-100 text-red-700 hover:bg-red-200">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="p-4 text-center text-gray-500">Abhi koi payment method add nahi hua hai.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-blue-500">
                <h3 class="font-bold text-lg mb-4">Multi-Domain Manager</h3>
                <form action="/admin/settings/domain" method="POST" class="flex gap-2">
                    <input type="text" name="newDomain" placeholder="https://domain.com" required class="flex-1 p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-bold">Add</button>
                </form>
                <div class="mt-4 flex flex-wrap gap-2">
                    <% settings.activeDomains.forEach(domain => { %>
                        <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs font-bold"><%= domain %></span>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>