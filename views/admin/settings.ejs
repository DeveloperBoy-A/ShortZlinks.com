<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-red-600">Super Admin Configuration</h1>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-red-500 xl:col-span-2">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2"><i class="fas fa-chart-line text-red-500"></i> Revenue & CPM Engine</h3>
                <form action="/admin/settings/update-cpm" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium mb-1">Global Default CPM ($)</label>
                        <input type="number" step="0.01" name="baseCpm" value="<%= settings.defaultCpm %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Admin Profit Margin (%)</label>
                        <input type="number" name="adminCommissionPercent" value="<%= settings.adminCommissionPercent %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Verification Ad Steps</label>
                        <input type="number" name="adSteps" min="1" max="4" value="<%= settings.adSteps %>" class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600 outline-none">
                    </div>
                    
                    <div class="md:col-span-3">
                        <label class="block text-sm font-medium mb-1">Country-Wise CPM Rates (JSON Format)</label>
                        <textarea name="countryRates" rows="4" class="w-full p-3 border rounded dark:bg-gray-700 dark:border-gray-600 font-mono text-sm outline-none"><%= JSON.stringify(Object.fromEntries(settings.countryRates)) %></textarea>
                        <p class="text-xs text-gray-500 mt-1">Format example: {"US": 10.00, "IN": 5.00, "GB": 8.00}</p>
                    </div>

                    <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded font-bold hover:bg-red-700">Save CPM Engine</button>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-green-500">
                <h3 class="font-bold text-lg mb-4">Create New Payment Method</h3>
                <form action="/admin/settings/payment-methods" method="POST" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1">Method Name</label>
                            <input type="text" name="name" required class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">Min Payout ($)</label>
                            <input type="number" name="minPayout" required class="w-full p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                        </div>
                    </div>
                    <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded font-bold hover:bg-green-700 w-full">Add Method</button>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-blue-500">
                <h3 class="font-bold text-lg mb-4">Multi-Domain Manager</h3>
                <form action="/admin/settings/domain" method="POST" class="flex gap-2">
                    <input type="text" name="newDomain" placeholder="https://domain.com" required class="flex-1 p-2 border rounded dark:bg-gray-700 dark:border-gray-600">
                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-bold">Add</button>
                </form>
                <div class="mt-4 flex flex-wrap gap-2">
                    <% settings.activeDomains.forEach(domain => { %>
                        <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs font-bold"><%= domain %></span>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
