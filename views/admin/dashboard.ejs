<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        <h1 class="text-3xl font-bold mb-6 text-red-600">Super Admin Dashboard</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-red-500">
                <p class="text-gray-500 text-sm font-bold uppercase">Pending Payouts</p>
                <h3 class="text-3xl font-black text-red-600"><%= pendingWithdrawals %></h3>
                <a href="/admin/withdrawals" class="text-xs text-blue-500 hover:underline mt-2 inline-block">Review Now &rarr;</a>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-blue-500">
                <p class="text-gray-500 text-sm font-bold uppercase">Total Users</p>
                <h3 class="text-3xl font-black text-blue-600"><%= totalUsers %></h3>
                <a href="/admin/users" class="text-xs text-blue-500 hover:underline mt-2 inline-block">Manage Users &rarr;</a>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-green-500">
                <p class="text-gray-500 text-sm font-bold uppercase">System Status</p>
                <h3 class="text-2xl font-black text-green-500">Online</h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-l-4 border-yellow-500">
                <p class="text-gray-500 text-sm font-bold uppercase">Active Setup</p>
                <a href="/admin/settings" class="text-sm font-bold text-gray-700 dark:text-gray-300 hover:text-primary mt-2 block">Go to Configuration &rarr;</a>
            </div>
        </div>

        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-6 rounded-lg">
            <h2 class="text-xl font-bold text-red-800 dark:text-red-300 mb-2">Welcome to God Mode</h2>
            <p class="text-red-600 dark:text-red-400">As a Super Admin, you control the revenue split, ad steps, and user payouts. Always ensure user traffic sources are valid before approving any withdrawals to protect your Ad Network accounts.</p>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>

