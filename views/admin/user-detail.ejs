<%- include('../partials/header') %>
<div class="flex flex-1 flex-col md:flex-row overflow-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900">
        
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold">Investigating: <span class="text-primary"><%= viewedUser.email %></span></h1>
            <a href="/admin/users" class="bg-gray-300 dark:bg-gray-600 px-4 py-2 rounded text-sm hover:bg-gray-400">Back to Users</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-yellow-500">
                <p class="text-sm font-bold text-gray-500 uppercase">Pending Wallet</p>
                <h3 class="text-3xl font-black text-yellow-600">$<%= viewedUser.walletBalance.toFixed(2) %></h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-green-500">
                <p class="text-sm font-bold text-gray-500 uppercase">Lifetime Earned</p>
                <h3 class="text-3xl font-black text-green-600">$<%= viewedUser.lifetimeEarnings.toFixed(2) %></h3>
            </div>
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border-t-4 border-blue-500">
                <p class="text-sm font-bold text-gray-500 uppercase">Total Withdrawn</p>
                <h3 class="text-3xl font-black text-blue-600">$<%= viewedUser.totalWithdrawn.toFixed(2) %></h3>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md">
                <h3 class="font-bold text-lg mb-4 border-b pb-2">Declared Traffic Sources</h3>
                <% if(viewedUser.declaredTrafficSources.length > 0) { %>
                    <ul class="list-disc pl-5 space-y-1 text-gray-600 dark:text-gray-400">
                        <% viewedUser.declaredTrafficSources.forEach(source => { %>
                            <li><%= source %></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="text-gray-500 italic">No traffic sources declared yet.</p>
                <% } %>
            </div>

            <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md">
                <h3 class="font-bold text-lg mb-4 border-b pb-2">Billing Identity</h3>
                <p><strong>Name:</strong> <%= viewedUser.firstName %> <%= viewedUser.lastName %></p>
                <p><strong>Country:</strong> <%= viewedUser.country %></p>
                <p><strong>Phone:</strong> <%= viewedUser.phoneNumber %></p>
                <p><strong>IP Setup:</strong> <%= viewedUser.apiToken %></p>
            </div>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>

