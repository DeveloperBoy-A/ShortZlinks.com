<%- include('partials/header') %>
<main class="flex-grow flex flex-col items-center justify-center p-6 overflow-hidden">
    <div class="max-w-6xl w-full flex flex-col md:flex-row items-center justify-between mt-10">
        <div class="w-full md:w-1/2 text-center md:text-left z-10 hero-text">
            <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
                Shorten. Share. <br> <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">Earn Money.</span>
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300 mb-8">
                Join our premium Publisher network. Drive traffic to your links and earn top CPM rates globally. We share <%= 100 - settings.adminCommissionPercent %>% of the ad revenue directly with you!
            </p>
            <a href="/login" class="px-8 py-4 bg-primary text-white text-xl font-bold rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition transform inline-block">
                Start Earning Now <i class="fas fa-arrow-right ml-2"></i>
            </a>
        </div>
        
        <div class="w-full md:w-1/2 mt-12 md:mt-0 relative flex justify-center hero-image">
            <div class="w-64 h-64 md:w-96 md:h-96 bg-gradient-to-br from-primary to-secondary rounded-full blur-3xl opacity-30 absolute top-0"></div>
            <i class="fas fa-link text-9xl text-gray-800 dark:text-gray-100 relative z-10 floating-icon" style="filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));"></i>
        </div>
    </div>
</main>

<script>
    // GSAP Animations
    gsap.from(".hero-text", { duration: 1.2, x: -100, opacity: 0, ease: "power3.out" });
    gsap.from(".hero-image", { duration: 1.2, x: 100, opacity: 0, ease: "power3.out", delay: 0.2 });
    
    // Continuous 3D Float
    gsap.to(".floating-icon", {
        y: 20,
        rotationX: 10,
        rotationY: -10,
        duration: 2,
        yoyo: true,
        repeat: -1,
        ease: "sine.inOut"
    });
</script>
<%- include('partials/footer') %>
