<header id="navbar" class="fixed top-0 left-0 right-0 z-50 glass-nav border-b dark:border-gray-800 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            
            <div class="flex items-center gap-4">
                <button id="mobileMenuBtn" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <a href="/" class="text-2xl font-bold text-primary">
                    <img src="/logo.png" alt="<%= siteName %>" class="h-8 w-auto">
                </a>
            </div>

            <div class="flex items-center gap-4">
                
                <div class="relative">
                    <button id="notifBtn" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 relative">
                        <i class="fas fa-bell text-lg"></i>
                        <span class="absolute top-1 right-1 bg-red-500 text-white text-[10px] px-1 rounded-full">3</span>
                    </button>
                    <div id="notifDropdown" class="hidden absolute right-0 mt-2 w-64 bg-white dark:bg-gray-800 shadow-xl rounded-xl border dark:border-gray-700 p-4">
                        <p class="text-sm">No new notifications.</p>
                    </div>
                </div>

                <div class="relative">
                    <button id="langBtn" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
                        <i class="fas fa-globe text-lg"></i>
                    </button>
                    <div id="langDropdown" class="hidden absolute right-0 mt-2 w-32 bg-white dark:bg-gray-800 shadow-xl rounded-xl border dark:border-gray-700 py-2">
                        <a href="#" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">English</a>
                    </div>
                </div>

                <% if(user){ %>
                <div class="relative">
                    <button id="profileBtn" class="flex items-center gap-2">
                        <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=<%= user.email %>" class="w-9 h-9 rounded-full border">
                    </button>
                    
                    <div id="profileDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 shadow-xl rounded-xl border dark:border-gray-700 py-2 z-50">
                        <div class="px-4 py-2 border-b dark:border-gray-700">
                            <p class="text-xs text-gray-500">Balance</p>
                            <p class="font-bold text-primary">$<%= typeof balance !== 'undefined' ? balance : '0.00' %></p>
                        </div>
                        <a href="/user/settings" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">My Profile</a>
                        <a href="/user/activity" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">Account Activity</a>
                        <a href="/user/security" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">Manage 2FA</a>
                        <a href="/auth/logout" class="block px-4 py-2 text-red-500 hover:bg-red-50">Logout</a>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</header>

<script>
    // Dropdown toggles
    const setupDropdown = (btnId, menuId) => {
        const btn = document.getElementById(btnId);
        const menu = document.getElementById(menuId);
        if(!btn || !menu) return;
        
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            menu.classList.toggle('hidden');
        });
    };

    setupDropdown('notifBtn', 'notifDropdown');
    setupDropdown('langBtn', 'langDropdown');
    setupDropdown('profileBtn', 'profileDropdown');

    // Close on outside click
    document.addEventListener('click', () => {
        document.getElementById('notifDropdown')?.classList.add('hidden');
        document.getElementById('langDropdown')?.classList.add('hidden');
        document.getElementById('profileDropdown')?.classList.add('hidden');
    });

    // Mobile Menu logic (Assuming existing ID 'mobileMenu' exists in sidebar.ejs)
    const mobileMenuBtn = document.getElementById("mobileMenuBtn");
    const mobileMenu = document.getElementById("mobileMenu"); 
    if(mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.onclick = () => mobileMenu.classList.remove("hidden");
    }

    // Scroll effect
    window.addEventListener("scroll", () => {
        const nav = document.getElementById("navbar");
        if(window.scrollY > 15) nav.classList.add("shadow-xl");
        else nav.classList.remove("shadow-xl");
    });
</script>
