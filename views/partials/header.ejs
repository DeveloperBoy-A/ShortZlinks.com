<nav class="sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 shadow-sm">

    <div class="max-w-7xl mx-auto px-3 lg:px-6">

        <div class="h-16 flex items-center justify-between">

            <!-- Left -->
            <div class="flex items-center gap-3">

                <% if(user){ %>
                <button id="sidebarToggle"
                    class="relative text-2xl text-gray-700 dark:text-gray-200 hover:text-primary">
                    <i class="fas fa-bars"></i>
                    <span class="absolute -top-1 -right-1 w-2.5 h-2.5 bg-red-600 rounded-full"></span>
                </button>
                <% } %>

                <a href="/" class="flex items-center gap-2">

                    <img src="/images/logo.png"
                        class="w-44 h-auto"
                        alt="ShortZlinks">

                </a>

            </div>

            <!-- Right -->
            <div class="flex items-center gap-3">

                <!-- Dark Mode -->

                <button id="themeToggle"
                    class="w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800">

                    <i class="fas fa-moon dark:hidden"></i>

                    <i class="fas fa-sun hidden dark:block text-yellow-400"></i>

                </button>

                <% if(user){ %>

                <!-- Notification -->

                <div class="relative">

                    <button id="notificationBtn"
                        class="relative w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800">

                        <i class="fas fa-bell text-xl"></i>

                        <% if(notifications && notifications.length){ %>

                        <span
                            class="absolute -top-1 -right-1 bg-red-600 text-white text-[11px] px-1.5 rounded-full">

                            <%= notifications.length %>

                        </span>

                        <% } %>

                    </button>

                    <!-- Notification Dropdown -->

                    <div id="notificationMenu"
                        class="hidden absolute right-0 mt-3 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-xl border dark:border-gray-700">

                        <div class="p-4 border-b dark:border-gray-700">

                            <h2 class="font-bold">Notifications</h2>

                        </div>

                        <div class="max-h-96 overflow-y-auto">

                            <% if(notifications && notifications.length){ %>

                            <% notifications.forEach(n=>{ %>

                            <a href="<%= n.link || '#' %>"
                                class="block px-4 py-3 hover:bg-gray-100 dark:hover:bg-gray-700">

                                <p class="font-medium"><%= n.title %></p>

                                <small class="text-gray-500"><%= n.message %></small>

                            </a>

                            <% }) %>

                            <% }else{ %>

                            <div class="p-6 text-center text-gray-500">

                                No Notifications

                            </div>

                            <% } %>

                        </div>

                    </div>

                </div>

                <!-- Language -->

                <div class="relative">

                    <button id="languageBtn"
                        class="w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800">

                        <i class="fas fa-language"></i>

                    </button>

                    <div id="languageMenu"
                        class="hidden absolute right-0 mt-3 w-44 bg-white dark:bg-gray-800 rounded-xl shadow-xl">

                        <a href="?lang=en" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">ðŸ‡ºðŸ‡¸ English</a>

                        <a href="?lang=hi" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700">ðŸ‡®ðŸ‡³ Hindi</a>

                    </div>

                </div>
                <!-- Profile -->
                <div class="relative">

                    <button id="profileBtn"
                        class="flex items-center gap-2 rounded-full">

                        <img
                            src="<%= user.avatar || '/images/default-avatar.png' %>"
                            class="w-10 h-10 rounded-full border-2 border-primary object-cover">

                    </button>

                    <div id="profileMenu"
                        class="hidden absolute right-0 mt-3 w-72 bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">

                        <div class="px-5 py-4 border-b dark:border-gray-700">

                            <p class="text-gray-500 text-sm">Welcome!</p>

                            <h3 class="font-bold text-lg">
                                <%= user.name %>
                            </h3>

                        </div>

                        <a href="/user/profile"
                            class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 dark:hover:bg-gray-700">

                            <i class="fas fa-user w-5"></i>

                            My Profile

                        </a>

                        <a href="/user/activity"
                            class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 dark:hover:bg-gray-700">

                            <i class="fas fa-history w-5"></i>

                            Account Activity

                        </a>

                        <a href="/user/2fa"
                            class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 dark:hover:bg-gray-700">

                            <i class="fas fa-shield-alt w-5"></i>

                            Manage 2FA

                        </a>

                        <div class="px-5 py-3 border-t border-b dark:border-gray-700">

                            <div class="flex justify-between">

                                <span class="font-semibold">
                                    Balance
                                </span>

                                <span class="text-green-600 font-bold">

                                    $<%= Number(user.balance || 0).toFixed(4) %>

                                </span>

                            </div>

                        </div>

                        <a href="/logout"
                            class="flex items-center gap-3 px-5 py-4 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20">

                            <i class="fas fa-sign-out-alt"></i>

                            Logout

                        </a>

                    </div>

                </div>

                <% } %>

            </div>

        </div>

    </div>

</nav>

<script>

const toggle=(btn,menu)=>{

const b=document.getElementById(btn);

const m=document.getElementById(menu);

if(!b||!m)return;

b.onclick=(e)=>{

e.stopPropagation();

m.classList.toggle("hidden");

};

};

toggle("profileBtn","profileMenu");

toggle("notificationBtn","notificationMenu");

toggle("languageBtn","languageMenu");

document.addEventListener("click",()=>{

["profileMenu","notificationMenu","languageMenu"].forEach(id=>{

const el=document.getElementById(id);

if(el)el.classList.add("hidden");

});

});

document.getElementById("themeToggle")?.addEventListener("click",()=>{

document.documentElement.classList.toggle("dark");

localStorage.theme=document.documentElement.classList.contains("dark")?"dark":"light";

});

</script>