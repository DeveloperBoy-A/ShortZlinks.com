<style>
    .glass-nav { background:rgba(255,255,255,.85); backdrop-filter:blur(16px); }
    .dark .glass-nav { background:rgba(17,24,39,.85); }
    .nav-link { position:relative; font-weight:600; transition:.3s; }
    .nav-link:after { content:''; position:absolute; left:0; bottom:-6px; width:0; height:2px; background:#4f46e5; transition:.3s; }
    .nav-link:hover:after { width:100%; }
</style>

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 glass-nav border-b dark:border-gray-800 transition-all duration-300">
    <div class="max-w-[1400px] mx-auto px-4">
        <div class="flex justify-between items-center h-16">
            
            <div class="flex items-center gap-4">
                <button id="mobileMenuBtn" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                    <i class="fas fa-bars text-xl dark:text-white"></i>
                </button>
                <a href="/" class="text-2xl font-bold text-primary">
                    <img src="/logo.png" alt="<%= siteName %>" class="h-8 w-auto">
                </a>
            </div>

            <div class="flex items-center gap-3">
                
                <button class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 relative dark:text-white transition">
                    <i class="fas fa-bell text-lg"></i>
                    <span class="absolute top-1 right-1 bg-secondary text-white text-[10px] w-4 h-4 flex items-center justify-center rounded-full">3</span>
                </button>

                <button class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white transition">
                    <i class="fas fa-globe text-lg"></i>
                </button>

                <% if(user){ %>
                <div class="relative">
                    <button id="profileBtn" class="flex items-center gap-2 transition">
                        <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=<%= user.email %>" class="w-9 h-9 rounded-full border-2 border-primary">
                    </button>
                    
                    <div id="profileDropdown" class="hidden absolute right-0 mt-3 w-56 bg-white dark:bg-gray-800 shadow-2xl rounded-xl border dark:border-gray-700 py-2 z-50">
                        <div class="px-4 py-2 border-b dark:border-gray-700">
                            <p class="text-xs text-gray-500">Welcome!</p>
                            <p class="font-bold dark:text-white"><%= user.username || 'User' %></p>
                        </div>
                        <a href="/user/settings" class="block px-4 py-2.5 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white"><i class="fas fa-user w-6"></i> My Profile</a>
                        <a href="/user/activity" class="block px-4 py-2.5 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white"><i class="fas fa-history w-6"></i> Account Activity</a>
                        <a href="/user/security" class="block px-4 py-2.5 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white"><i class="fas fa-shield-alt w-6"></i> Manage 2FA</a>
                        <div class="px-4 py-2.5 font-bold text-primary"><i class="fas fa-dollar-sign w-6"></i> Balance: $<%= typeof balance !== 'undefined' ? balance : '0.0000' %></div>
                        <a href="/auth/logout" class="block px-4 py-2.5 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 font-semibold"><i class="fas fa-sign-out-alt w-6"></i> Logout</a>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</header>

<script>
    // Logic for Profile Dropdown
    const profileBtn = document.getElementById('profileBtn');
    const profileDropdown = document.getElementById('profileDropdown');

    if(profileBtn) {
        profileBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            profileDropdown.classList.toggle('hidden');
        });
    }

    document.addEventListener('click', () => {
        if(profileDropdown) profileDropdown.classList.add('hidden');
    });

    // Scroll Shadow Logic
    window.addEventListener("scroll",()=>{
        const nav = document.getElementById("navbar");
        if(window.scrollY > 15) nav.classList.add("shadow-xl");
        else nav.classList.remove("shadow-xl");
    });
</script>
