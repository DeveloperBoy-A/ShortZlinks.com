<aside class="w-full md:w-72 bg-white dark:bg-gray-800 border-r dark:border-gray-700 flex flex-col shrink-0 min-h-screen transition-all duration-300 z-40 relative">
    
    <div class="md:hidden flex justify-between items-center p-4 border-b dark:border-gray-700 bg-white dark:bg-gray-800">
        <a href="/" class="font-black text-xl border-2 border-gray-800 dark:border-gray-200 rounded px-2 py-1 text-gray-800 dark:text-gray-200">
            Short<span class="text-primary">Z</span>links<sub class="text-[10px]">.com</sub>
        </a>
        <button id="menuToggle" class="text-gray-600 dark:text-gray-300 focus:outline-none bg-blue-500 text-white p-2 rounded">
            <i class="fas fa-bars fa-lg"></i>
        </button>
    </div>

    <div id="sidebarMenu" class="hidden md:flex flex-col h-full overflow-y-auto custom-scrollbar">
        
        <div class="hidden md:flex justify-center items-center py-6 border-b dark:border-gray-700">
            <a href="/" class="font-black text-2xl border-2 border-gray-800 dark:border-gray-200 rounded px-2 py-1 text-gray-800 dark:text-gray-200 shadow-sm">
                Short<span class="text-primary text-3xl">Z</span>links<sub class="text-xs font-bold">.com</sub>
            </a>
        </div>

        <div class="flex flex-col items-center py-8 border-b dark:border-gray-700">
            <div class="text-sm font-bold text-gray-800 dark:text-gray-200 flex items-center gap-2 mb-5">
                <i class="far fa-id-badge"></i> <%= siteName %> Member
            </div>
            
            <div class="relative">
                <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=<%= user.email %>&backgroundColor=c0aede" alt="Profile" class="w-24 h-24 rounded-full border-4 border-white dark:border-gray-700 shadow-lg object-cover bg-blue-100">
                <span class="absolute top-1 right-2 w-4 h-4 bg-green-500 border-2 border-white dark:border-gray-800 rounded-full"></span>
            </div>
            
            <span class="mt-4 font-bold text-blue-600 dark:text-blue-400 text-lg"><%= user.email.split('@')[0] %></span>
        </div>

        <ul class="flex-1 py-4 space-y-1">
            
            <% if (user.role !== 'admin') { %>
                
                <li>
                    <a href="/user/dashboard" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition <%= path === '/user/dashboard' ? 'bg-gray-50 dark:bg-gray-700' : '' %>">
                        <i class="fas fa-tachometer-alt w-5 text-center text-blue-600"></i>
                        <span class="font-medium">Dashboard</span>
                    </a>
                </li>

                <li>
                    <button onclick="toggleDropdown('manageLinksMenu')" class="w-full flex items-center justify-between px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition focus:outline-none">
                        <div class="flex items-center gap-4">
                            <i class="fas fa-link w-5 text-center text-blue-400"></i>
                            <span class="font-medium">Manage Links</span>
                        </div>
                        <i class="fas fa-ellipsis-v text-gray-400"></i>
                    </button>
                    <ul id="manageLinksMenu" class="hidden flex-col bg-gray-50 dark:bg-gray-900/50 py-2 border-l-4 border-blue-400 ml-4">
                        <li><a href="/user/links" class="block px-12 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary font-medium">All Links</a></li>
                    </ul>
                </li>

                <li>
                    <a href="#" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-bullhorn w-5 text-center text-red-400"></i>
                        <span class="font-medium">Announcements</span>
                    </a>
                </li>

                <li class="bg-blue-600 text-white my-2 shadow-md">
                    <a href="#" class="flex items-center gap-4 px-6 py-4 hover:bg-blue-700 transition">
                        <i class="fab fa-telegram-plane w-5 text-center text-xl"></i>
                        <span class="font-bold">Telegram LinkShortner Bot</span>
                    </a>
                </li>

                <li>
                    <a href="/user/withdrawals" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-wallet w-5 text-center text-purple-400"></i>
                        <span class="font-medium">Payment</span>
                    </a>
                </li>

                <li>
                    <button onclick="toggleDropdown('toolsMenu')" class="w-full flex items-center justify-between px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition focus:outline-none">
                        <div class="flex items-center gap-4">
                            <i class="fas fa-layer-group w-5 text-center text-red-300"></i>
                            <span class="font-medium">Tools</span>
                        </div>
                        <i class="fas fa-ellipsis-v text-gray-400"></i>
                    </button>
                    <ul id="toolsMenu" class="hidden flex-col bg-gray-50 dark:bg-gray-900/50 py-3 space-y-3">
                        <li><a href="#" class="flex items-center gap-3 px-10 text-sm text-gray-700 dark:text-gray-300 hover:text-primary font-medium"><i class="fas fa-user-astronaut text-blue-500 w-5"></i> Telegram Bot</a></li>
                        <li><a href="#" class="flex items-center gap-3 px-10 text-sm text-gray-700 dark:text-gray-300 hover:text-primary font-medium"><i class="fas fa-external-link-square-alt text-green-500 w-5"></i> Quick Link</a></li>
                        <li><a href="/user/tools" class="flex items-center gap-3 px-10 text-sm text-gray-700 dark:text-gray-300 hover:text-primary font-medium"><i class="fas fa-compress-arrows-alt text-purple-500 w-5"></i> Mass Shrinker</a></li>
                        <li><a href="/user/tools" class="flex items-center gap-3 px-10 text-sm text-gray-700 dark:text-gray-300 hover:text-primary font-medium"><i class="fas fa-file-code text-blue-700 w-5"></i> Full Page Script</a></li>
                        <li><a href="#" class="flex items-center gap-3 px-10 text-sm text-gray-700 dark:text-gray-300 hover:text-primary font-medium"><i class="fas fa-code text-green-600 w-5"></i> Developers API</a></li>
                    </ul>
                </li>

                <li>
                    <a href="/user/referrals" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-user-friends w-5 text-center text-yellow-500"></i>
                        <span class="font-medium">Referrals</span>
                    </a>
                </li>

                <li>
                    <button onclick="toggleDropdown('securityMenu')" class="w-full flex items-center justify-between px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition focus:outline-none">
                        <div class="flex items-center gap-4 relative">
                            <i class="fas fa-lock w-5 text-center text-pink-500"></i>
                            <span class="font-medium">Security</span>
                            <span class="absolute -top-1 -right-2 w-2 h-2 bg-red-600 rounded-full animate-pulse"></span>
                        </div>
                        <i class="fas fa-ellipsis-v text-gray-400"></i>
                    </button>
                    <ul id="securityMenu" class="hidden flex-col bg-gray-50 dark:bg-gray-900/50 py-2 border-l-4 border-pink-500 ml-4">
                        <li><a href="/user/settings" class="block px-12 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary font-medium">Update Password</a></li>
                    </ul>
                </li>

                <li>
                    <button onclick="toggleDropdown('settingsMenu')" class="w-full flex items-center justify-between px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition focus:outline-none">
                        <div class="flex items-center gap-4">
                            <i class="fas fa-cog w-5 text-center text-green-400"></i>
                            <span class="font-medium">Settings</span>
                        </div>
                        <i class="fas fa-ellipsis-v text-gray-400"></i>
                    </button>
                    <ul id="settingsMenu" class="hidden flex-col bg-gray-50 dark:bg-gray-900/50 py-2 border-l-4 border-green-400 ml-4">
                        <li><a href="/user/settings" class="block px-12 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary font-medium">Profile</a></li>
                        <li><a href="/user/settings" class="block px-12 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary font-medium">Withdrawal Info</a></li>
                    </ul>
                </li>

                <li>
                    <a href="#" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-life-ring w-5 text-center text-red-500"></i>
                        <span class="font-medium">Support</span>
                    </a>
                </li>
            <% } else { %>
                <li>
                    <a href="/admin/dashboard" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-tachometer-alt w-5 text-center text-red-600"></i>
                        <span class="font-medium">God Mode Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/users" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-users w-5 text-center text-blue-500"></i>
                        <span class="font-medium">Manage Users</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/withdrawals" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-money-check-alt w-5 text-center text-green-500"></i>
                        <span class="font-medium">Review Payouts</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/settings" class="flex items-center gap-4 px-6 py-3 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        <i class="fas fa-cogs w-5 text-center text-gray-500"></i>
                        <span class="font-medium">Platform Settings</span>
                    </a>
                </li>
            <% } %>

        </ul>
        
        <div class="p-6 border-t dark:border-gray-700">
            <a href="/auth/logout" class="flex items-center justify-center gap-2 w-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 py-3 rounded-lg font-bold hover:bg-red-100 dark:hover:bg-red-900/40 transition">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>

    </div>
</aside>

<script>
    // Toggle Mobile Sidebar
    document.getElementById('menuToggle').addEventListener('click', () => {
        document.getElementById('sidebarMenu').classList.toggle('hidden');
    });

    // Dropdown Accordion Logic
    function toggleDropdown(menuId) {
        const menu = document.getElementById(menuId);
        
        // Agar pehle se open hai, toh close karo
        if (!menu.classList.contains('hidden')) {
            menu.classList.add('hidden');
        } else {
            // Optional: Agar ek open hone par dusre close karne hain toh yahan code add kar sakte hain
            menu.classList.remove('hidden');
        }
    }
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 10px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #475569;
    }
</style>
